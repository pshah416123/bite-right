# Required for real restaurant search (Google Place Autocomplete).
# 1. Go to https://console.cloud.google.com/
# 2. Create or select a project → APIs & Services → Library
# 3. Enable "Places API" (the legacy one, not "Places API (New)")
# 4. APIs & Services → Credentials → Create credentials → API key
# 5. Copy the key below. For dev: leave key restriction as "None" so the
#    SERVER can call Google. (Restricting to "iOS apps" or "HTTP referrers"
#    blocks the backend and search will return 0 results.)
GOOGLE_PLACES_API_KEY= your_google_api_key_here

# Optional: Yelp Fusion API key for food-photo fallback.
# Yelp's business image_url is almost always a food/dish photo — much better than Google exteriors.
# Get one free at https://www.yelp.com/developers/v3/manage_app (500 calls/day free tier).
YELP_API_KEY=your_yelp_api_key_here

# Public base URL of this API (no trailing slash). Used to return absolute image URLs in responses.
# Dev: http://localhost:4000  Production: https://your-api.biteright.app
PUBLIC_API_URL=http://localhost:4000

# Supabase (server-side persistence — Phase 1)
# 1. Go to https://supabase.com/dashboard → your project → Settings → API
# 2. Copy "Project URL" and "service_role" key (NOT the anon key)
# IMPORTANT: The service_role key bypasses Row Level Security.
#            Never expose it in client/mobile code — it is server-only.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
