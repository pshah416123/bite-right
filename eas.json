{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "store",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://bite-right.onrender.com"
      },
      "ios": {
        "autoIncrement": true
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://bite-right.onrender.com"
      },
      "ios": {
        "autoIncrement": true
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "REPLACE_AFTER_APP_STORE_CONNECT_CREATE"
      }
    }
  }
}
